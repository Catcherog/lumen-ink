# GLM (智谱AI) API Key
# 从 https://bigmodel.cn/usercenter/proj-mgmt/apikeys 获取
GLM_API_KEY=your_api_key_here

# 备用环境变量名（与 GLM_API_KEY 等效）
# ZHIPU_API_KEY=your_api_key_here

# Server port
PORT=3001

# Auth password (simple password protection for MVP)
AUTH_PASSWORD=changeme

# JWT secret (auto-generated if not set)
JWT_SECRET=gemini-image-editor-secret-2026

# Provider API Key 加密密钥（可选，建议设置 32 字节以上随机字符串）
# 未设置时，将基于 JWT_SECRET 派生密钥，更换 JWT_SECRET 会导致已有加密 Key 无法解密
PROVIDER_ENCRYPTION_KEY=your-random-encryption-key-min-32-chars

# 默认 Provider ID（可选，优先级高于 Provider 列表中的 isDefault 标记）
DEFAULT_PROVIDER_ID=
