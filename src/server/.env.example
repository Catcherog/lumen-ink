# 默认 Provider 1: 即梦 / Seedream（火山引擎方舟）— 默认启用且为默认 Provider
# 从 https://console.volcengine.com/ark 获取 API Key
SEEDREAM_API_KEY=your_seedream_api_key_here

# 默认 Provider 2: GPT / OpenAI — 默认启用
# 从 https://platform.openai.com/api-keys 获取 API Key
OPENAI_API_KEY=your_openai_api_key_here

# ===== 以下为可选 Provider 的环境变量回退（仅当手动新增对应类型 Provider 时使用）=====

# GLM (智谱AI) — 可选，手动新增 GLM 类型 Provider 时作为 Key 回退
# 从 https://bigmodel.cn/usercenter/proj-mgmt/apikeys 获取
GLM_API_KEY=your_glm_api_key_here

# Gemini — 可选，手动新增 Gemini 类型 Provider 时作为 Key 回退
# 从 https://aistudio.google.com/apikey 获取
GEMINI_API_KEY=your_gemini_api_key_here

# Server port
PORT=3001

# Auth password (simple password protection for MVP)
AUTH_PASSWORD=changeme

# JWT secret (auto-generated if not set)
JWT_SECRET=gemini-image-editor-secret-2026

# Provider API Key 加密密钥（可选，建议设置 32 字节以上随机字符串）
# 未设置时，将基于 JWT_SECRET 派生密钥，更换 JWT_SECRET 会导致已有加密 Key 无法解密
PROVIDER_ENCRYPTION_KEY=your-random-encryption-key-min-32-chars

# 默认 Provider ID（可选，优先级高于 Provider 列表中的 isDefault 标记）
DEFAULT_PROVIDER_ID=
